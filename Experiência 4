def analisar_clima():

  soma_temperaturas = 0.0

  dias_quentes = 0

  alerta_extremo = False

  

  # O range(1, 8) vai de 1 até 7

  for dia in range(1, 8):

    try:

      tempo = float(input(f"Digite a temperatura do dia {dia}: "))

      soma_temperaturas += tempo

      

      # Verifica se o dia foi quente

      if tempo > 35.0:

        dias_quentes += 1

      

      # Verifica se houve temperatura extrema

      if tempo > 45.0 or tempo < -5.0:

        alerta_extremo = True

        

    except ValueError:

      print("Erro: Digite um número válido para a temperatura.")

      return # Interrompe a função em caso de erro de digitação



  media = soma_temperaturas / 7

  

  print("-" * 30)

  print(f"Média semanal: {media:.1f}°C")

  print(f"Dias acima de 35°C: {dias_quentes}")

  

  if alerta_extremo:

    print("CUIDADO: Condições climáticas perigosas detectadas!")

  else:

    print("Clima dentro da normalidade operacional.")



analisar_clima()



