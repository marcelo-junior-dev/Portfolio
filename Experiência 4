def sistema_notas_turma():

  try:

    total_alunos = int(input("Quantos alunos existem na turma? "))

    

    for j in range(1, total_alunos + 1):

      print(f"\n--- Dados do Aluno {j} ---")

      aluno_nome = input("Nome do aluno: ")

      nota1 = float(input("Nota 1: "))

      nota2 = float(input("Nota 2: "))

      

      # Cálculo da média 

      media_aluno = (nota1 + nota2) / 2

      

      # Decisão aluno

      if media_aluno >= 7.0:

        print(f"Status: {aluno_nome} - APROVADO com média {media_aluno:.1f}")

      elif media_aluno >= 5.0:

        print(f"Status: {aluno_nome} - RECUPERAÇÃO (Média: {media_aluno:.1f})")

      else:

        print(f"Status: {aluno_nome} - REPROVADO (Média: {media_aluno:.1f})")

        

  except ValueError:

    print("Erro: Certifique-se de digitar números válidos para as notas e quantidade.")



sistema_notas_turma()



