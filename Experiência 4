def processar_vendas():

  total_compra = 0.0

  itens_comprados = 0

  

  try:

    quantidade_tipos = int(input("Quantos produtos diferentes foram comprados? "))

    

    for i in range(quantidade_tipos):

      print(f"\n--- Produto {i+1} ---")

      nome = input("Nome do produto: ")

      preco_itens = float(input("Preço unitário: "))

      quantidade_itens = int(input("Quantidade deste produto: "))

      

      if preco_itens <= 0 or quantidade_itens <= 0:

        print(f"Erro: Valores inválidos para {nome}")

      else:

        subtotal = preco_itens * quantidade_itens

        total_compra += subtotal

        itens_comprados += quantidade_itens

    

    # Lógica de Descontos

    if total_compra > 500.00:

      total_final = total_compra * 0.90 # 10% de desconto

      print("\nDesconto de 10% aplicado!")

    elif total_compra > 200.00:

      total_final = total_compra * 0.95 # 5% de desconto

      print("\nDesconto de 5% aplicado!")

    else:

      total_final = total_compra

      

    print(f"Resumo: {itens_comprados} itens. Total a pagar: R${total_final:.2f}")

    

  except ValueError:

    print("Erro: Por favor, insira valores numéricos válidos.")



# Chamada da função

processar_vendas()



